Options -Indexes
DirectoryIndex index.html
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTP_HOST} !^uwinbeverage\.ru$ [NC,OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://uwinbeverage.ru%{REQUEST_URI} [R=301,L,NE]

  RewriteCond %{THE_REQUEST} \s/+index\.html(?:[\s?]) [NC]
  RewriteRule ^index\.html$ https://uwinbeverage.ru/ [R=301,L]

  RewriteRule ^page147799916\.html$ / [R=301,L]
  RewriteRule ^aqua/?$ / [R=301,L]

  RewriteRule (^|/)(?:\.git|references|tmp)(?:/|$) - [F,L,NC]
  RewriteRule (^|/)\.(?:env|gitignore|gitattributes)$ - [F,L,NC]
  RewriteRule \.(?:md|log|ini|bak|sql)$ - [F,L,NC]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  <FilesMatch "\.(?:html|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(?:avif|gif|ico|jpe?g|png|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.pdf$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType application/pdf "access plus 7 days"
</IfModule>
